/**
 * TurboQuant -- Fused MoE Metal compute shaders
 *
 * Single-dispatch MoE: processes ALL active experts for one MoE layer
 * in parallel, eliminating per-matmul dispatch overhead.
 *
 * Architecture:
 *   Phase 1: moe_gate_up_fused — 8 experts x expert_dim gate+up matmuls
 *   Phase 2: moe_swiglu         — SwiGLU activation on all experts
 *   Phase 3: moe_down_accum     — down projection + weighted accumulate
 *
 * Total: 3 dispatches per MoE layer (was 27 per layer with batched mode,
 * or 810 per-matmul dispatches in immediate mode).
 *
 * IQ2_XXS fused dequant-dot is inlined in each kernel. The codebook
 * tables live in constant memory (2176 bytes), shared by all threads.
 *
 * Weight data is accessed via zero-copy (newBufferWithBytesNoCopy)
 * on Apple Silicon unified memory — no upload required.
 */
#include <metal_stdlib>
#include <metal_math>
using namespace metal;

/* ============================================================
 * MoE GPU parameters — passed as constant buffer
 * ============================================================ */
struct MoeGpuParams {
    int    active_experts[8];     /* expert indices */
    float  expert_weights[8];     /* routing weights */
    int    num_active;            /* how many experts active (max 8) */
    int    expert_dim;            /* intermediate dim per expert */
    int    hidden_dim;            /* model hidden dim */
    int    num_experts_total;     /* total experts in layer */

    /* Weight layout: byte offsets from base of weight buffer */
    uint64_t gate_offsets[8];     /* offset to gate weight for each active expert */
    uint64_t up_offsets[8];       /* offset to up weight for each active expert */
    uint64_t down_offsets[8];     /* offset to down weight for each active expert */

    uint   gate_type;             /* legacy — kept for struct alignment */

    /* IQ2_XXS block geometry */
    int    blocks_per_row_gate;   /* in_dim / 256 for gate/up (input = hidden_dim) */
    int    row_bytes_gate;        /* blocks_per_row_gate * block_bytes (IQ2_XXS=66) */
    int    blocks_per_row_down;   /* in_dim / 256 for down (input = expert_dim) */
    int    row_bytes_down;        /* blocks_per_row_down * block_bytes (IQ2_S=82) */

    /* Per-expert quant types: 16 = IQ2_XXS, 22 = IQ2_S */
    int    gate_types[8];         /* per-expert gate weight quant type */
    int    up_types[8];           /* per-expert up weight quant type */
    int    down_types[8];         /* per-expert down weight quant type */
    int    gate_row_bytes;        /* row bytes for gate/up (may differ from row_bytes_gate for IQ2_S) */
    int    down_row_bytes;        /* row bytes for down (may differ from row_bytes_down for IQ2_S) */
};

