/**
 * Partial IQ2_S dot for blocks assigned to this thread.
 * Returns partial sum — caller must SIMD-reduce.
 *
 * IQ2_S block: 82 bytes per 256 elements
 * Layout: d(fp16,2) + qs[32](grid low 8) + signs[32] + qh[8](grid high 2) + scales[8](4-bit sub-block)
 *
 * Ported from dequant_iq2_s() in tq_gguf_quants.c
 */
inline float iq2s_dot_partial(
    device const uchar* row_ptr,
    threadgroup const float* shared_input,
    device const uint64_t* iq2s_grid,   /* 1024-entry codebook buffer */
    uint n_blocks,
    uint tid,
    uint tg_size)
{
    float partial_sum = 0.0f;

    for (uint b = tid; b < n_blocks; b += tg_size) {
        device const uchar* blk = row_ptr + b * 82;

        half d_half = *reinterpret_cast<device const half*>(blk);
        float d = float(d_half);

        device const uchar* qs    = blk + 2;       /* 32 bytes: grid index low 8 bits */
        device const uchar* signs = blk + 34;      /* 32 bytes: sign bits (direct bitmask) */
        device const uchar* qh    = blk + 66;      /* 8 bytes: grid index high 2 bits */
        device const uchar* scales = blk + 74;     /* 8 bytes: 4-bit sub-block scales */

        uint base_idx = b * 256;

        for (uint ib32 = 0; ib32 < 8; ib32++) {
            /* Two 4-bit sub-block scales packed per byte */
            float db0 = d * (0.5f + float(scales[ib32] & 0xF)) * 0.25f;
            float db1 = d * (0.5f + float(scales[ib32] >> 4)) * 0.25f;

            for (uint l = 0; l < 4; l++) {
                float dl = (l < 2) ? db0 : db1;

                /* 10-bit grid index: low 8 from qs, high 2 from qh */
                uint grid_idx = uint(qs[l]) | ((uint(qh[ib32]) << (8u - 2u * l)) & 0x300u);
                uint64_t grid_val = iq2s_grid[grid_idx];
                uchar sign = signs[l];

                uint elem_idx = base_idx + ib32 * 32 + l * 8;

                float group_sum = 0.0f;
                for (uint j = 0; j < 8; j++) {
                    float w = float((grid_val >> (8u * j)) & 0xFF);
                    if (sign & (1u << j)) w = -w;
                    group_sum += w * shared_input[elem_idx + j];
                }
                partial_sum += dl * group_sum;
            }
            qs += 4;
            signs += 4;
        }
    }
    return partial_sum;
}

/**
 * SIMD + threadgroup reduction to get final scalar from partial sums.
 * Returns the total in thread 0 of the threadgroup only.
 */
inline float reduce_sum(
    float partial_sum,
    uint tid,
    uint tg_size,
    threadgroup float* simd_sums)
{
    /* SIMD (warp) reduction */
    partial_sum += simd_shuffle_down(partial_sum, 16);
    partial_sum += simd_shuffle_down(partial_sum, 8);
    partial_sum += simd_shuffle_down(partial_sum, 4);
    partial_sum += simd_shuffle_down(partial_sum, 2);
    partial_sum += simd_shuffle_down(partial_sum, 1);

    uint simd_lane = tid % 32;
    uint simd_group = tid / 32;

    if (simd_lane == 0) {
        simd_sums[simd_group] = partial_sum;
    }
    threadgroup_barrier(mem_flags::mem_threadgroup);

    if (tid == 0) {
        uint n_simd = (tg_size + 31) / 32;
        float total = 0.0f;
        for (uint s = 0; s < n_simd; s++) {
            total += simd_sums[s];
        }
        return total;
    }
    return 0.0f; /* only tid==0 has the result */
}


/* ============================================================
 * Phase 1: moe_gate_up_fused
 *
 * One dispatch for all active experts' gate AND up projections.
 * Grid: num_active * expert_dim threadgroups
 *   - Threadgroup gid encodes (expert_local, row)
 *   - expert_local = gid / expert_dim
 *   - row = gid % expert_dim
 *
 * Each threadgroup computes:
 *   gate_outputs[expert_local * expert_dim + row] = IQ2_dot(gate_row, input)
 *   up_outputs[expert_local * expert_dim + row]   = IQ2_dot(up_row, input)
 *
 * Input vector is cached once in threadgroup shared memory.
 * ============================================================ */

kernel void moe_gate_up_fused(
    device const uchar*    weights       [[buffer(0)]],   /* base of all expert weights */
    device const float*    input         [[buffer(1)]],   /* [hidden_dim] */
    device float*          gate_outputs  [[buffer(2)]],   /* [num_active * expert_dim] */
    device float*          up_outputs    [[buffer(3)]],   /* [num_active * expert_dim] */
    constant MoeGpuParams& params        [[buffer(4)]],
    device const uint64_t* iq2s_grid     [[buffer(5)]],   /* IQ2_S codebook (1024 entries) */
    threadgroup float*     shared_mem    [[threadgroup(0)]],
    uint  gid     [[threadgroup_position_in_grid]],
    uint  tid     [[thread_index_in_threadgroup]],
    uint  tg_size [[threads_per_threadgroup]])
{
    /* Decode which expert and which row this threadgroup handles */
    int expert_local = int(gid) / params.expert_dim;
    int row          = int(gid) % params.expert_dim;

    if (expert_local >= params.num_active) return;

    uint in_dim = uint(params.hidden_dim);
    uint n_blocks = uint(params.blocks_per_row_gate);

    /* Layout shared memory:
     * [0 .. in_dim-1]  : input cache
     * [in_dim .. in_dim+7] : simd reduction scratch (8 floats) */
    threadgroup float* shared_input = shared_mem;
    threadgroup float* simd_sums = shared_mem + in_dim;

    /* Cooperative load of input vector */
    for (uint i = tid; i < in_dim; i += tg_size) {
        shared_input[i] = input[i];
    }
    threadgroup_barrier(mem_flags::mem_threadgroup);

    /* Compute gate matmul row — dispatch based on per-expert quant type */
    uint64_t gate_off = params.gate_offsets[expert_local];
    int gate_type = params.gate_types[expert_local];
    /* Row bytes depend on quant type: IQ2_XXS=66, IQ2_S=82 per block */
    uint gate_rb = (gate_type == 22) ? uint(n_blocks) * 82u : uint(params.row_bytes_gate);
    device const uchar* gate_row = weights + gate_off + uint(row) * gate_rb;
    float gate_partial;
    if (gate_type == 22) { /* IQ2_S */
        gate_partial = iq2s_dot_partial(gate_row, shared_input, iq2s_grid, n_blocks, tid, tg_size);
    } else { /* IQ2_XXS (16) or default */
        gate_partial = iq2xxs_dot_partial(gate_row, shared_input, n_blocks, tid, tg_size);
    }
    float gate_val = reduce_sum(gate_partial, tid, tg_size, simd_sums);

    /* Store gate result (only tid 0 has the correct total) */
    if (tid == 0) {
        gate_outputs[expert_local * params.expert_dim + row] = gate_val;
    }

    /* Barrier before reusing simd_sums for up computation */
    threadgroup_barrier(mem_flags::mem_threadgroup);

    /* Compute up matmul row — dispatch based on per-expert quant type */
    uint64_t up_off = params.up_offsets[expert_local];
    int up_type = params.up_types[expert_local];
    uint up_rb = (up_type == 22) ? uint(n_blocks) * 82u : uint(params.row_bytes_gate);
    device const uchar* up_row = weights + up_off + uint(row) * up_rb;
    float up_partial;
    if (up_type == 22) { /* IQ2_S */
        up_partial = iq2s_dot_partial(up_row, shared_input, iq2s_grid, n_blocks, tid, tg_size);
    } else { /* IQ2_XXS (16) or default */
        up_partial = iq2xxs_dot_partial(up_row, shared_input, n_blocks, tid, tg_size);
    }
    float up_val = reduce_sum(up_partial, tid, tg_size, simd_sums);

    if (tid == 0) {
        up_outputs[expert_local * params.expert_dim + row] = up_val;
    }
}


/* ============================================================
 * Phase 2: moe_swiglu
 *
 * SwiGLU activation: gate_outputs[i] = silu(gate[i]) * up[i]
 * In-place on gate_outputs, reading from up_outputs.
 *
 * Grid: num_active * expert_dim threads (1D, trivially parallel).
 * ============================================================ */

kernel void moe_swiglu(
    device float*          gate_outputs  [[buffer(0)]],   /* [num_active * expert_dim] in/out */
    device const float*    up_outputs    [[buffer(1)]],   /* [num_active * expert_dim] */
    constant MoeGpuParams& params        [[buffer(2)]],
    uint  gid [[thread_position_in_grid]])
{
    uint total = uint(params.num_active) * uint(params.expert_dim);
    if (gid >= total) return;

    float g = gate_outputs[gid];
    float u = up_outputs[gid];

    /* SiLU(x) = x * sigmoid(x) = x / (1 + exp(-x)) */
    float sigmoid = 1.0f / (1.0f + exp(-g));
    float silu = g * sigmoid;

    gate_outputs[gid] = silu * u;
}


/* ============================================================
 * Phase 3: moe_down_accum
 *
 * Down projection for all experts + weighted accumulation.
 *
 * Grid: hidden_dim threadgroups.
 * Each threadgroup computes ONE output element:
 *   output[row] = sum over active experts of:
 *     expert_weight[k] * IQ2_dot(down_row[k], hb[k])
 *
 * hb[k] = gate_outputs[k * expert_dim .. (k+1)*expert_dim - 1]
 *         (after SwiGLU, stored in gate_outputs buffer).
 *
 * The input to down projection is expert_dim per expert, and each
 * expert has its own down weight matrix. We iterate over all active
 * experts within the same threadgroup to maximize data reuse.
 * ============================================================ */

kernel void moe_down_accum(
    device const uchar*    weights       [[buffer(0)]],   /* base of all expert weights */
    device const float*    hb_all        [[buffer(1)]],   /* [num_active * expert_dim] (SwiGLU output) */
    device float*          output        [[buffer(2)]],   /* [hidden_dim] */
    constant MoeGpuParams& params        [[buffer(3)]],
    device const uint64_t* iq2s_grid     [[buffer(4)]],   /* IQ2_S codebook (1024 entries) */
    threadgroup float*     shared_mem    [[threadgroup(0)]],
    uint  gid     [[threadgroup_position_in_grid]],
    uint  tid     [[thread_index_in_threadgroup]],
    uint  tg_size [[threads_per_threadgroup]])
{
    uint row = gid;
    if (row >= uint(params.hidden_dim)) return;

    uint exp_dim = uint(params.expert_dim);
    uint n_blocks_down = uint(params.blocks_per_row_down);

    /* Shared memory layout:
     * [0 .. exp_dim-1]     : hb cache for current expert
     * [exp_dim .. exp_dim+7] : simd reduction scratch */
    threadgroup float* shared_hb = shared_mem;
    threadgroup float* simd_sums = shared_mem + exp_dim;

    float accum = 0.0f;

    /* Iterate over active experts */
    for (int k = 0; k < params.num_active; k++) {
        float ew = params.expert_weights[k];
        if (ew == 0.0f) continue;

        /* Cooperatively load this expert's hb into shared memory */
        device const float* hb_expert = hb_all + uint(k) * exp_dim;
        for (uint i = tid; i < exp_dim; i += tg_size) {
            shared_hb[i] = hb_expert[i];
        }
        threadgroup_barrier(mem_flags::mem_threadgroup);

        /* Compute dot for this expert's down projection row — type-dispatched */
        uint64_t down_off = params.down_offsets[k];
        int down_type = params.down_types[k];
        uint down_rb = (down_type == 22) ? n_blocks_down * 82u : uint(params.row_bytes_down);
        device const uchar* down_row = weights + down_off + row * down_rb;
        float dot_partial;
        if (down_type == 22) { /* IQ2_S — now uses device buffer for grid */
            dot_partial = iq2s_dot_partial(down_row, shared_hb, iq2s_grid, n_blocks_down, tid, tg_size);
        } else { /* IQ2_XXS (16) or default */
            dot_partial = iq2xxs_dot_partial(down_row, shared_hb, n_blocks_down, tid, tg_size);
        }
        float dot_val = reduce_sum(dot_partial, tid, tg_size, simd_sums);

        if (tid == 0) {
            accum += ew * dot_val;
        }

        threadgroup_barrier(mem_flags::mem_threadgroup);
    }

    if (tid == 0) {
        output[row] = accum;
    }
}


/* ============================================================
 * Alternative: moe_gate_up_fused for Q8_0 weights
 *
 * Same structure but uses Q8_0 dequant instead of IQ2_XXS.
 * Used when expert weights have been cached as Q8_0.
 * ============================================================ */

/* Q8_0 partial dot product */
inline float q8_0_dot_partial(
    device const uchar* row_ptr,
    threadgroup const float* shared_input,
    uint n_blocks,
    uint tid,
    uint tg_size)
{
    float partial_sum = 0.0f;

    for (uint b = tid; b < n_blocks; b += tg_size) {
        device const uchar* blk = row_ptr + b * 34;
        float d = float(*reinterpret_cast<device const half*>(blk));
        device const char* qs = reinterpret_cast<device const char*>(blk + 2);
        uint base_idx = b * 32;

        float block_sum = 0.0f;
        for (uint j = 0; j < 32; j += 8) {
            block_sum += float(qs[j + 0]) * shared_input[base_idx + j + 0];
            block_sum += float(qs[j + 1]) * shared_input[base_idx + j + 1];
            block_sum += float(qs[j + 2]) * shared_input[base_idx + j + 2];
            block_sum += float(qs[j + 3]) * shared_input[base_idx + j + 3];
            block_sum += float(qs[j + 4]) * shared_input[base_idx + j + 4];
            block_sum += float(qs[j + 5]) * shared_input[base_idx + j + 5];
            block_sum += float(qs[j + 6]) * shared_input[base_idx + j + 6];
            block_sum += float(qs[j + 7]) * shared_input[base_idx + j + 7];
        }
        partial_sum += d * block_sum;
    }
    return partial_sum;
}
